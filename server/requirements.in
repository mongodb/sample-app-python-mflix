pillow>=12.2.0          # Transitive dep via voyageai (Pillow 12.2.0 security fixes)
requests>=2.33.0        # Transitive dep via langsmith/voyageai (CVE-2026-25645 fix)
idna>=3.15              # Transitive dep via httpx/requests (Dependabot #70)
